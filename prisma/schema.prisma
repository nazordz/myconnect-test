// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  moduleFormat    = "cjs"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

enum ConciergeSessionStatus {
  ACTIVE
  ARCHIVED
  CLOSED
}

enum ConciergeMessageRole {
  SYSTEM
  USER
  ASSISTANT
  TOOL
}

enum ToolCallStatus {
  REQUESTED
  SUCCEEDED
  FAILED
}

enum LlmProvider {
  OPENAI
  ANTHROPIC
  GEMINI
  OTHER
}

model Event {
  id        String   @id @default(uuid()) @db.Uuid
  title     String
  location  String?
  startAt   DateTime @map("start_at")
  endAt     DateTime @map("end_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  attendees EventAttendee[]
  sessions  ConciergeSession[]

  @@index([startAt])
  @@index([endAt])
  @@index([location])
  @@map("events")
}

model Attendee {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  headline  String?
  bio       String?
  company   String?
  role      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  eventLinks EventAttendee[]

  @@index([name])
  @@index([company])
  @@index([role])
  @@map("attendees")
}

model EventAttendee {
  id         String @id @default(uuid()) @db.Uuid
  eventId    String @db.Uuid @map("event_id")
  attendeeId String @db.Uuid @map("attendee_id")

  skills     String[]
  lookingFor String? @map("looking_for")
  openToChat Boolean @default(true) @map("open_to_chat")

  profileText String? @map("profile_text")

  embedding          Unsupported("vector(1536)")?
  embeddingModel     String? @map("embedding_model")
  embeddingUpdatedAt DateTime? @map("embedding_updated_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  event    Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  attendee Attendee @relation(fields: [attendeeId], references: [id], onDelete: Cascade)

  sessions         ConciergeSession[]
  requesterMatches MatchSuggestion[] @relation("RequesterMatches")
  candidateMatches MatchSuggestion[] @relation("CandidateMatches")

  @@unique([eventId, attendeeId])
  @@index([eventId])
  @@index([attendeeId])
  @@index([eventId, openToChat])
  @@map("event_attendees")
}

model ConciergeSession {
  id              String @id @default(uuid()) @db.Uuid
  eventId         String @db.Uuid @map("event_id")
  eventAttendeeId String @db.Uuid @map("event_attendee_id")

  status        ConciergeSessionStatus @default(ACTIVE)
  lastIntent    String? @map("last_intent")
  lastMessageAt DateTime? @map("last_message_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  event         Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventAttendee EventAttendee    @relation(fields: [eventAttendeeId], references: [id], onDelete: Cascade)
  messages      ConciergeMessage[]

  @@unique([eventId, eventAttendeeId])
  @@index([eventId])
  @@index([eventAttendeeId])
  @@index([status])
  @@map("concierge_sessions")
}

model ConciergeMessage {
  id        String @id @default(uuid()) @db.Uuid
  sessionId String @db.Uuid @map("session_id")

  role    ConciergeMessageRole
  content Json
  rawText String? @map("raw_text")

  requestId String? @map("request_id")

  llmProvider      LlmProvider? @map("llm_provider")
  llmModel         String? @map("llm_model")
  promptTokens     Int? @map("prompt_tokens")
  completionTokens Int? @map("completion_tokens")
  totalTokens      Int? @map("total_tokens")
  latencyMs        Int? @map("latency_ms")

  createdAt DateTime @default(now()) @map("created_at")

  session   ConciergeSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  toolCalls ConciergeToolCall[]
  matches   MatchSuggestion[]
  feedbacks MessageFeedback[]

  @@index([sessionId, createdAt])
  @@index([requestId])
  @@index([role])
  @@map("concierge_messages")
}

model ConciergeToolCall {
  id        String @id @default(uuid()) @db.Uuid
  messageId String @db.Uuid @map("message_id")

  toolName   String @map("tool_name")
  toolCallId String? @map("tool_call_id")
  status     ToolCallStatus

  input        Json
  output       Json?
  latencyMs    Int? @map("latency_ms")
  errorMessage String? @map("error_message")

  createdAt DateTime @default(now()) @map("created_at")

  message ConciergeMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([toolName])
  @@index([status])
  @@map("concierge_tool_calls")
}

model MatchSuggestion {
  id        String @id @default(uuid()) @db.Uuid
  messageId String @db.Uuid @map("message_id")

  requesterEventAttendeeId String @db.Uuid @map("requester_event_attendee_id")
  candidateEventAttendeeId String @db.Uuid @map("candidate_event_attendee_id")

  rank              Int
  score             Int
  rationale         String
  sharedGround      Json @map("shared_ground")
  draftIntroMessage String? @map("draft_intro_message")

  searchScore Float? @map("search_score")

  createdAt DateTime @default(now()) @map("created_at")

  message   ConciergeMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  requester EventAttendee    @relation("RequesterMatches", fields: [requesterEventAttendeeId], references: [id], onDelete: Cascade)
  candidate EventAttendee    @relation("CandidateMatches", fields: [candidateEventAttendeeId], references: [id], onDelete: Cascade)

  @@unique([messageId, candidateEventAttendeeId])
  @@index([messageId])
  @@index([requesterEventAttendeeId])
  @@index([candidateEventAttendeeId])
  @@index([score])
  @@index([rank])
  @@map("match_suggestions")
}

model MessageFeedback {
  id        String @id @default(uuid()) @db.Uuid
  messageId String @db.Uuid @map("message_id")
  rating    Int
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")

  message ConciergeMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([rating])
  @@map("message_feedback")
}
