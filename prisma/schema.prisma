// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat = "cjs"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  extensions = [vector]
}

/// =========================
/// ENUMS
/// =========================

enum ConciergeSessionStatus {
  ACTIVE
  ARCHIVED
  CLOSED
}

enum ConciergeMessageRole {
  SYSTEM
  USER
  ASSISTANT
  TOOL
}

enum ToolCallStatus {
  REQUESTED
  SUCCEEDED
  FAILED
}

enum LlmProvider {
  OPENAI
  ANTHROPIC
  GEMINI
  OTHER
}

/// =========================
/// CORE DOMAIN
/// =========================

model Event {
  id          String   @id @default(uuid()) @db.Uuid
  title       String
  location    String?
  startAt     DateTime
  endAt       DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  attendees   EventAttendee[]
  sessions    ConciergeSession[]

  @@index([startAt])
  @@index([endAt])
  @@index([location])
  @@map("events")
}

model Attendee {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  headline    String?
  bio         String?
  company     String?
  role        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  eventLinks  EventAttendee[]

  @@index([name])
  @@index([company])
  @@index([role])
  @@map("attendees")
}

model EventAttendee {
  id                 String    @id @default(uuid()) @db.Uuid
  eventId            String    @db.Uuid
  attendeeId         String    @db.Uuid

  /// Per-event profile fields
  skills             String[]
  lookingFor         String?
  openToChat         Boolean   @default(true)

  /// Normalized/searchable text snapshot used for embeddings + hybrid search
  profileText        String?

  /// pgvector metadata
  embedding          Unsupported("vector(1536)")?
  embeddingModel     String?
  embeddingUpdatedAt DateTime?

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  event              Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  attendee           Attendee  @relation(fields: [attendeeId], references: [id], onDelete: Cascade)

  sessions           ConciergeSession[]

  requesterMatches   MatchSuggestion[] @relation("RequesterMatches")
  candidateMatches   MatchSuggestion[] @relation("CandidateMatches")

  @@unique([eventId, attendeeId])
  @@index([eventId])
  @@index([attendeeId])
  @@index([eventId, openToChat])
  @@map("event_attendees")
}

/// =========================
/// CONCIERGE STATE
/// =========================

model ConciergeSession {
  id               String                  @id @default(uuid()) @db.Uuid
  eventId          String                  @db.Uuid
  eventAttendeeId  String                  @db.Uuid

  status           ConciergeSessionStatus  @default(ACTIVE)
  lastIntent       String?
  lastMessageAt    DateTime?

  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  event            Event                   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventAttendee    EventAttendee           @relation(fields: [eventAttendeeId], references: [id], onDelete: Cascade)
  messages         ConciergeMessage[]

  @@unique([eventId, eventAttendeeId])
  @@index([eventId])
  @@index([eventAttendeeId])
  @@index([status])
  @@map("concierge_sessions")
}

model ConciergeMessage {
  id                String                @id @default(uuid()) @db.Uuid
  sessionId         String                @db.Uuid

  role              ConciergeMessageRole
  /// Structured content for persistence/resume
  content           Json
  /// Plain-text projection for easier debugging/logging/search
  rawText           String?

  /// Request correlation / observability
  requestId         String?

  /// LLM metadata
  llmProvider       LlmProvider?
  llmModel          String?
  promptTokens      Int?
  completionTokens  Int?
  totalTokens       Int?
  latencyMs         Int?

  createdAt         DateTime              @default(now())

  session           ConciergeSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  toolCalls         ConciergeToolCall[]
  matches           MatchSuggestion[]
  feedbacks         MessageFeedback[]

  @@index([sessionId, createdAt])
  @@index([requestId])
  @@index([role])
  @@map("concierge_messages")
}

model ConciergeToolCall {
  id               String         @id @default(uuid()) @db.Uuid
  messageId        String         @db.Uuid

  toolName         String
  toolCallId       String?
  status           ToolCallStatus

  input            Json
  output           Json?
  latencyMs        Int?
  errorMessage     String?

  createdAt        DateTime       @default(now())

  message          ConciergeMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([toolName])
  @@index([status])
  @@map("concierge_tool_calls")
}

/// =========================
/// MATCH RESULTS
/// =========================

model MatchSuggestion {
  id                       String            @id @default(uuid()) @db.Uuid
  messageId                String            @db.Uuid

  requesterEventAttendeeId String            @db.Uuid
  candidateEventAttendeeId String            @db.Uuid

  rank                     Int
  score                    Int
  rationale                String
  sharedGround             Json
  draftIntroMessage        String?

  /// Optional retrieval-stage score before final AI scoring
  searchScore              Float?

  createdAt                DateTime          @default(now())

  message                  ConciergeMessage  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  requester                EventAttendee     @relation("RequesterMatches", fields: [requesterEventAttendeeId], references: [id], onDelete: Cascade)
  candidate                EventAttendee     @relation("CandidateMatches", fields: [candidateEventAttendeeId], references: [id], onDelete: Cascade)

  @@unique([messageId, candidateEventAttendeeId])
  @@index([messageId])
  @@index([requesterEventAttendeeId])
  @@index([candidateEventAttendeeId])
  @@index([score])
  @@index([rank])
  @@map("match_suggestions")
}

/// =========================
/// FEEDBACK
/// =========================

model MessageFeedback {
  id          String            @id @default(uuid()) @db.Uuid
  messageId   String            @db.Uuid
  rating      Int
  notes       String?
  createdAt   DateTime          @default(now())

  message     ConciergeMessage  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([rating])
  @@map("message_feedback")
}
