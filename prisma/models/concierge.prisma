enum ConciergeSessionStatus {
  ACTIVE
  ARCHIVED
  CLOSED
}

enum ConciergeMessageRole {
  SYSTEM
  USER
  ASSISTANT
  DEVELOPER
}

enum ToolCallStatus {
  REQUESTED
  SUCCEEDED
  FAILED
}

model ConciergeSession {
  id         String @id @default(uuid()) @db.Uuid
  eventId    String @map("event_id") @db.Uuid
  attendeeId String @map("attendee_id") @db.Uuid

  status        ConciergeSessionStatus @default(ACTIVE)
  lastIntent    String?                @map("last_intent")
  lastMessageAt DateTime?              @map("last_message_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  event     Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  attendee  Attendee           @relation(fields: [attendeeId], references: [id], onDelete: Cascade)
  messages  ConciergeMessage[]

  @@unique([eventId, attendeeId])
  @@index([eventId])
  @@index([attendeeId])
  @@index([status])
  @@map("concierge_sessions")
}

model ConciergeMessage {
  id        String @id @default(uuid()) @db.Uuid
  sessionId String @map("session_id") @db.Uuid

  role    ConciergeMessageRole
  message String

  createdAt DateTime @default(now()) @map("created_at")

  session   ConciergeSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  feedbacks MessageFeedback[]

  @@index([sessionId, createdAt])
  @@index([role])
  @@map("concierge_messages")
}

model MessageFeedback {
  id        String   @id @default(uuid()) @db.Uuid
  messageId String   @map("message_id") @db.Uuid
  rating    Int
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")

  message ConciergeMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([rating])
  @@map("message_feedback")
}
